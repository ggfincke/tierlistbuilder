# .env.example
# template for .env.local — copy & fill, do NOT commit .env.local
#
# convex deployment URL — auto-populated by `npm run dev` / `npx convex dev`.
# this is the only frontend-side env var the app reads at runtime
VITE_CONVEX_URL=

# convex-side env vars — these live on your convex deployment, NOT here.
# password auth (email + password) needs no OAuth registration; google &
# apple OAuth providers land in a follow-up PR & will add their own vars.
# local dev is the default. configure SITE_URL + Convex Auth keys via:
#
#   npm run convex:auth:local
#
# for a cloud dev deployment, use `npx convex deployment select dev` first and
# set SITE_URL without `--deployment local`.
#
# see convex/README.md for the full first-time setup walkthrough

# marketplace seed script (`npm run seed:marketplace`). must match the value
# set on the deployment via `npx convex env set CONVEX_SEED_SECRET <hex>`.
# the deployment also needs CONVEX_SEED_ENABLED=true.
CONVEX_SEED_SECRET=
