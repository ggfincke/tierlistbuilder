# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# wrangler files
.wrangler
.dev.vars*
!.dev.vars.example
.env*
!.env.example

# typescript build cache — produced by `tsc -b`, lives at the path each
# tsconfig points to via tsBuildInfoFile (we use node_modules/.tmp/), but
# orphan files outside that path should never be tracked
*.tsbuildinfo

# convex generated files — the runtime .js, type .d.ts, & sourcemaps under
# convex/_generated/ are committed so both `tsc -b` & `vite build` can run
# in CI w/o a deployment. they regenerate on every `npx convex dev` run, so
# expect occasional small diffs when schema or function signatures change.
# ai/ dir is per-user tooling output & never committed
convex/_generated/ai/
.convex

# convex AI files dropped by `npx convex dev`
.agents
.claude
skills-lock.json

# Example assets (local dev only)
/examples

# Generated screenshots (local dev only)
/screenshots
