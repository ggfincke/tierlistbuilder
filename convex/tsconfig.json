{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "allowJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@tierlistbuilder/contracts": ["../packages/contracts/index.ts"],
      "@tierlistbuilder/contracts/*": ["../packages/contracts/*"]
    }
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
