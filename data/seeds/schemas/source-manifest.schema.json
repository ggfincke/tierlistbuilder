{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tierlistbuilder.local/schemas/seed-source-manifest.schema.json",
  "title": "Tierlistbuilder Seed Source Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "datasetKey",
    "releaseId",
    "authorEmail",
    "templates"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "datasetKey": {
      "$ref": "#/$defs/datasetKey"
    },
    "releaseId": {
      "$ref": "#/$defs/releaseId"
    },
    "authorEmail": {
      "type": "string",
      "minLength": 3,
      "maxLength": 254,
      "pattern": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$"
    },
    "rankingSeeds": {
      "$ref": "#/$defs/rankingSeeds"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/template"
      }
    }
  },
  "$defs": {
    "datasetKey": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "releaseId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96,
      "pattern": "^[0-9a-z]+(?:-[0-9a-z]+)*$"
    },
    "templateExternalId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[a-z0-9]+(?::[a-z0-9]+(?:-[a-z0-9]+)*)+$"
    },
    "entryExternalId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "allOf": [
        {
          "not": {
            "pattern": "^/"
          }
        },
        {
          "not": {
            "pattern": "\\\\"
          }
        },
        {
          "not": {
            "pattern": "(^|/)\\.\\.(/|$)"
          }
        }
      ]
    },
    "category": {
      "enum": [
        "gaming",
        "movies",
        "anime",
        "music",
        "sports",
        "food",
        "books",
        "tech",
        "other"
      ]
    },
    "visibility": {
      "enum": ["public", "unlisted"]
    },
    "labelPolicy": {
      "enum": [
        "explicit-required",
        "explicit-or-filename-fallback",
        "filename-derived",
        "hidden"
      ]
    },
    "boardLabelSettings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "show": {
          "type": "boolean"
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "externalId",
        "folder",
        "title",
        "category",
        "description",
        "tags",
        "visibility",
        "labelPolicy",
        "criteria",
        "items"
      ],
      "properties": {
        "externalId": {
          "$ref": "#/$defs/templateExternalId"
        },
        "folder": {
          "$ref": "#/$defs/path"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "description": {
          "type": ["string", "null"],
          "maxLength": 500
        },
        "tags": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          }
        },
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "labelPolicy": {
          "$ref": "#/$defs/labelPolicy"
        },
        "labels": {
          "$ref": "#/$defs/boardLabelSettings"
        },
        "coverImage": {
          "$ref": "#/$defs/path"
        },
        "coverZoom": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 10
        },
        "suggestedTiers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "$ref": "#/$defs/suggestedTier"
          }
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/criterion"
          }
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "labelPolicy": {
                "const": "explicit-required"
              }
            },
            "required": ["labelPolicy"]
          },
          "then": {
            "properties": {
              "items": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["externalId", "image", "label"]
                }
              }
            }
          }
        }
      ]
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "externalId",
        "name",
        "shortName",
        "prompt",
        "axisTop",
        "axisBottom",
        "order",
        "isPrimary",
        "status"
      ],
      "properties": {
        "externalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "shortName": {
          "type": ["string", "null"],
          "maxLength": 16
        },
        "prompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "axisTop": {
          "type": ["string", "null"],
          "maxLength": 40
        },
        "axisBottom": {
          "type": ["string", "null"],
          "maxLength": 40
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "isPrimary": {
          "type": "boolean"
        },
        "status": {
          "enum": ["active", "hidden", "deprecated"]
        }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["externalId", "image"],
      "properties": {
        "externalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "image": {
          "$ref": "#/$defs/path"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "suggestedTier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "colorSpec"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "colorSpec": {
          "$ref": "#/$defs/tierColorSpec"
        },
        "rowColorSpec": {
          "$ref": "#/$defs/tierColorSpec"
        }
      }
    },
    "rankingSeeds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileSet", "defaultProfileCount", "profiles", "targets"],
      "properties": {
        "profileSet": {
          "$ref": "#/$defs/entryExternalId"
        },
        "defaultProfileCount": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "includeAllTemplates": {
          "type": "boolean"
        },
        "profiles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/rankingProfile"
          }
        },
        "targets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/rankingTarget"
          }
        }
      }
    },
    "rankingProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "displayName", "chaos", "contrarian"],
      "properties": {
        "key": {
          "$ref": "#/$defs/entryExternalId"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "chaos": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "contrarian": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "boostTermsByTarget": {
          "$ref": "#/$defs/rankingTermOverrides"
        },
        "dropTermsByTarget": {
          "$ref": "#/$defs/rankingTermOverrides"
        }
      }
    },
    "rankingTermOverrides": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "rankingTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateExternalId", "lanes"],
      "properties": {
        "templateExternalId": {
          "$ref": "#/$defs/templateExternalId"
        },
        "sampleProfileCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 64
        },
        "countAsTemplateUse": {
          "type": "boolean"
        },
        "lanes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/rankingLane"
          }
        },
        "curatedRankings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/curatedRanking"
          }
        }
      }
    },
    "rankingLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterionExternalId"],
      "properties": {
        "criterionExternalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "titleSuffix": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "boostTerms": {
          "$ref": "#/$defs/rankingTerms"
        },
        "dropTerms": {
          "$ref": "#/$defs/rankingTerms"
        },
        "profileBoostOverrides": {
          "$ref": "#/$defs/rankingTermOverrides"
        },
        "profileDropOverrides": {
          "$ref": "#/$defs/rankingTermOverrides"
        },
        "chaosMultiplier": {
          "type": "number",
          "minimum": 0,
          "maximum": 4
        },
        "contrarianMultiplier": {
          "type": "number",
          "minimum": 0,
          "maximum": 4
        },
        "featuredProfiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featuredProfile"
          }
        }
      }
    },
    "rankingTerms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "featuredProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileKey", "featuredRank", "featuredBadge"],
      "properties": {
        "profileKey": {
          "$ref": "#/$defs/entryExternalId"
        },
        "featuredRank": {
          "type": "integer",
          "minimum": 0
        },
        "featuredBadge": {
          "$ref": "#/$defs/rankingFeaturedBadge"
        }
      }
    },
    "curatedRanking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "externalId",
        "authorKey",
        "authorDisplayName",
        "criterionExternalId",
        "title",
        "description",
        "tiers",
        "tierGroups"
      ],
      "properties": {
        "externalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "authorKey": {
          "$ref": "#/$defs/entryExternalId"
        },
        "authorDisplayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "criterionExternalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "featuredRank": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "featuredBadge": {
          "oneOf": [
            {
              "$ref": "#/$defs/rankingFeaturedBadge"
            },
            {
              "type": "null"
            }
          ]
        },
        "coverage": {
          "enum": ["full-template", "partial-authoritative"]
        },
        "parentLabelByLabel": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "tiers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/suggestedTier"
          }
        },
        "tierGroups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/curatedTierGroup"
          }
        }
      }
    },
    "curatedTierGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tierName", "labels"],
      "properties": {
        "tierName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        }
      }
    },
    "rankingFeaturedBadge": {
      "enum": ["official", "editorial", "tournament", "creator"]
    },
    "tierColorSpec": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "index"],
          "properties": {
            "kind": {
              "const": "palette"
            },
            "index": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "hex"],
          "properties": {
            "kind": {
              "const": "custom"
            },
            "hex": {
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            }
          }
        }
      ]
    }
  }
}
