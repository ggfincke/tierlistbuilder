{
  "name": "tierlistbuilder",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "CONVEX_LOCAL_BACKEND_STARTUP_TIMEOUT_SECS=180 convex dev --local --start 'vite'",
    "dev:app": "vite",
    "dev:convex": "CONVEX_LOCAL_BACKEND_STARTUP_TIMEOUT_SECS=180 convex dev --local",
    "dev:cloud": "convex dev --cloud --start 'vite'",
    "convex:auth:local": "node scripts/setup-local-convex-auth.mjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && eslint .",
    "audit:dead-code": "knip --no-progress",
    "bundle:report": "node scripts/report-bundle-size.mjs",
    "measure:sync-payload": "tsx scripts/measure-board-sync-payload.ts",
    "audit:drag": "node scripts/drag-audit.mjs",
    "seed:marketplace": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline run data/seeds/marketplace-core.json --confirm-activation",
    "seed:marketplace:validate": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline validate data/seeds/marketplace-core.json",
    "seed:marketplace:build": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline build data/seeds/marketplace-core.json",
    "seed:marketplace:diff": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline diff data/seeds/marketplace-core.json",
    "seed:marketplace:preflight": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline preflight data/seeds/marketplace-core.json",
    "seed:marketplace:upload": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline upload data/seeds/marketplace-core.json",
    "seed:marketplace:apply": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline apply data/seeds/marketplace-core.json",
    "seed:marketplace:verify": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline verify data/seeds/marketplace-core.json",
    "seed:marketplace:cleanup": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline cleanup data/seeds/marketplace-core.json",
    "seed:rankings": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline rankings:run data/seeds/marketplace-core.json --confirm-activation",
    "seed:rankings:preflight": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline rankings:preflight data/seeds/marketplace-core.json",
    "seed:rankings:apply": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline rankings:apply data/seeds/marketplace-core.json",
    "seed:rankings:verify": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline rankings:verify data/seeds/marketplace-core.json",
    "seed:rankings:activate": "PYTHONPATH=scripts/seed_pipeline python3 -m seed_pipeline rankings:activate data/seeds/marketplace-core.json --confirm-activation",
    "seed:featured": "node scripts/promote-featured-trio.mjs",
    "db:reset": "python3 scripts/dev_reset.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots": "node scripts/screenshots.mjs",
    "preview": "vite preview",
    "version": "node scripts/check-changelog.mjs && git add CHANGELOG.md"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@babel/runtime": "^7.29.2",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tierlistbuilder/contracts": "^0.0.0",
    "@uiw/color-convert": "^2.9.6",
    "@uiw/react-color-shade-slider": "^2.9.6",
    "@uiw/react-color-wheel": "^2.9.6",
    "convex": "^1.36.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "pako": "^2.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.7",
    "react-router-dom": "^6.30.3",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-brace-style"
    ],
    "braceStyle": "allman",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 80,
    "arrowParens": "always"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "convex-test": "^0.0.50",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "knip": "^6.9.0",
    "playwright": "^1.59.1",
    "prettier": "^3.5.0",
    "prettier-plugin-brace-style": "^0.10.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.75.0"
  }
}
