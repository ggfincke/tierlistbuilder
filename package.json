{
  "name": "tierlistbuilder",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write . && eslint --fix .",
    "format:check": "prettier --check . && eslint .",
    "audit:drag": "node scripts/drag-audit.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshots": "node scripts/screenshots.mjs",
    "preview": "vite preview",
    "version": "node scripts/check-changelog.mjs && git add CHANGELOG.md"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@babel/runtime": "^7.29.2",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.2.1",
    "@uiw/color-convert": "^2.9.6",
    "@uiw/react-color-shade-slider": "^2.9.6",
    "@uiw/react-color-wheel": "^2.9.6",
    "convex": "^1.35.1",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "pako": "^2.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-brace-style"
    ],
    "braceStyle": "allman",
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 80,
    "arrowParens": "always"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "convex-test": "^0.0.50",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.59.1",
    "prettier": "^3.5.0",
    "prettier-plugin-brace-style": "^0.10.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "wrangler": "^4.75.0"
  }
}
