{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tierlistbuilder.local/schemas/seed-ranking-profiles.schema.json",
  "title": "Tierlistbuilder Seed Ranking Profiles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "profileSet",
    "defaultProfileCount",
    "profiles",
    "targets"
  ],
  "properties": {
    "schemaVersion": {
      "const": 2
    },
    "profileSet": {
      "$ref": "#/$defs/entryExternalId"
    },
    "defaultProfileCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 64
    },
    "includeAllTemplates": {
      "type": "boolean"
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {
        "$ref": "#/$defs/rankingProfile"
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rankingTarget"
      }
    }
  },
  "$defs": {
    "templateExternalId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 96,
      "pattern": "^[a-z0-9]+(?::[a-z0-9]+(?:-[a-z0-9]+)*)+$"
    },
    "entryExternalId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "rankingTermOverrides": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "rankingTerms": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "rankingFeaturedBadge": {
      "enum": ["official", "editorial", "tournament", "creator"]
    },
    "rankingProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "displayName", "chaos", "contrarian"],
      "properties": {
        "key": {
          "$ref": "#/$defs/entryExternalId"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "chaos": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "contrarian": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "boostTermsByTarget": {
          "$ref": "#/$defs/rankingTermOverrides"
        },
        "dropTermsByTarget": {
          "$ref": "#/$defs/rankingTermOverrides"
        }
      }
    },
    "rankingTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateExternalId", "lanes"],
      "properties": {
        "templateExternalId": {
          "$ref": "#/$defs/templateExternalId"
        },
        "sampleProfileCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 64
        },
        "countAsTemplateUse": {
          "type": "boolean"
        },
        "lanes": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {
            "$ref": "#/$defs/rankingLane"
          }
        },
        "curatedRankings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/curatedRanking"
          }
        }
      }
    },
    "rankingLane": {
      "type": "object",
      "additionalProperties": false,
      "required": ["criterionExternalId"],
      "properties": {
        "criterionExternalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "titleSuffix": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "boostTerms": {
          "$ref": "#/$defs/rankingTerms"
        },
        "dropTerms": {
          "$ref": "#/$defs/rankingTerms"
        },
        "profileBoostOverrides": {
          "$ref": "#/$defs/rankingTermOverrides"
        },
        "profileDropOverrides": {
          "$ref": "#/$defs/rankingTermOverrides"
        },
        "chaosMultiplier": {
          "type": "number",
          "minimum": 0,
          "maximum": 4
        },
        "contrarianMultiplier": {
          "type": "number",
          "minimum": 0,
          "maximum": 4
        },
        "featuredProfiles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featuredProfile"
          }
        }
      }
    },
    "featuredProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profileKey", "featuredRank", "featuredBadge"],
      "properties": {
        "profileKey": {
          "$ref": "#/$defs/entryExternalId"
        },
        "featuredRank": {
          "type": "integer",
          "minimum": 0
        },
        "featuredBadge": {
          "$ref": "#/$defs/rankingFeaturedBadge"
        }
      }
    },
    "curatedRanking": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "externalId",
        "authorKey",
        "authorDisplayName",
        "criterionExternalId",
        "title",
        "description",
        "tiers",
        "tierGroups"
      ],
      "properties": {
        "externalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "authorKey": {
          "$ref": "#/$defs/entryExternalId"
        },
        "authorDisplayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "criterionExternalId": {
          "$ref": "#/$defs/entryExternalId"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "featuredRank": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "featuredBadge": {
          "oneOf": [
            {
              "$ref": "#/$defs/rankingFeaturedBadge"
            },
            {
              "type": "null"
            }
          ]
        },
        "coverage": {
          "enum": ["full-template", "partial-authoritative"]
        },
        "parentLabelByLabel": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "tiers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "$ref": "#/$defs/suggestedTier"
          }
        },
        "tierGroups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/curatedTierGroup"
          }
        }
      }
    },
    "curatedTierGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tierName", "labels"],
      "properties": {
        "tierName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        }
      }
    },
    "suggestedTier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "colorSpec"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "colorSpec": {
          "$ref": "#/$defs/tierColorSpec"
        },
        "rowColorSpec": {
          "$ref": "#/$defs/tierColorSpec"
        }
      }
    },
    "tierColorSpec": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "index"],
          "properties": {
            "kind": {
              "const": "palette"
            },
            "index": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "hex"],
          "properties": {
            "kind": {
              "const": "custom"
            },
            "hex": {
              "type": "string",
              "pattern": "^#[0-9a-fA-F]{6}$"
            }
          }
        }
      ]
    }
  }
}
